{
    "name": "jaculus",
    "type": "module",
    "displayName": "Jaculus",
    "description": "Jaculus allows for running JavaScript code on embedded devices.",
    "version": "0.1.3",
    "engines": {
        "vscode": "^1.92.0"
    },
    "publisher": "cubicap",
    "pricing": "Free",
    "repository": {
        "type": "git",
        "url": "https://github.com/jaculus-org/Jaculus-vscode.git"
    },
    "author": {
        "name": "Petr Kubica (cubicap)",
        "email": "cubicap@email.cz"
    },
    "icon": "images/icon.png",
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onUri"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "jacly",
                "aliases": [
                    "Jacly",
                    "jacly"
                ],
                "extensions": [
                    ".jacly"
                ],
                "icon": {
                    "light": "./images/jacly.png",
                    "dark": "./images/jacly.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "jacly",
                "scopeName": "source.jacly",
                "path": "./syntaxes/jacly.tmLanguage.json"
            }
        ],
        "jsonLanguageParticipants": [
            {
                "languageId": "jacly"
            }
        ],
        "customEditors": [
            {
                "viewType": "jacly.editor",
                "displayName": "Jacly Editor",
                "selector": [
                    {
                        "filenamePattern": "*.jacly"
                    }
                ]
            }
        ],
        "commands": [
            {
                "command": "jaculus.Build",
                "title": "Build",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.Flash",
                "title": "Flash",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.Monitor",
                "title": "Monitor",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.BuildFlashMonitor",
                "title": "Build, Flash and Monitor",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.SelectComPort",
                "title": "Select COM port",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.SetLogLevel",
                "title": "Set Log Level",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.Start",
                "title": "Start a program",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.Stop",
                "title": "Stop a program",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.ShowVersion",
                "title": "Show version",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.ShowStatus",
                "title": "Show status",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.Format",
                "title": "Format storage",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.CheckForUpdates",
                "title": "Check for updates",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.ToggleMinimalMode",
                "title": "Toggle minimal mode",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.InstallBoard",
                "title": "Install firmware",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.ConfigWiFi",
                "title": "Configure WiFi",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.BrowseDeviceFiles",
                "title": "Browse Device Files",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.InstallLibrary",
                "title": "Install Library",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.RemoveLibrary",
                "title": "Remove Library",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.RefreshLibraries",
                "title": "Refresh Libraries",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.UpdateLibraries",
                "title": "Update Libraries",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.CreateProject",
                "title": "Create Project",
                "category": "Jaculus"
            },
            {
                "command": "jaculus.UpdateProject",
                "title": "Update Project",
                "category": "Jaculus"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "jaculus.BrowseDeviceFiles",
                    "when": "jaculus.fileBrowserRegistered"
                }
            ]
        },
        "keybindings": [
            {
                "command": "jaculus.BuildFlashMonitor",
                "key": "ctrl+alt+b",
                "mac": "cmd+ctrl+b"
            },
            {
                "command": "jaculus.Monitor",
                "key": "ctrl+alt+m",
                "mac": "cmd+ctrl+m"
            },
            {
                "command": "jaculus.SelectComPort",
                "key": "ctrl+alt+p",
                "mac": "cmd+ctrl+p"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "jaculus",
                    "title": "Jaculus",
                    "icon": "images/logo.png"
                }
            ]
        },
        "views": {
            "jaculus": [
                {
                    "id": "jaculusView",
                    "name": "Jaculus",
                    "icon": "images/logo.png"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "jaculusView",
                "contents": "Welcome to Jaculus! To start working create a new Jaculus project.\n[Create Project](command:jaculus.CreateProject)",
                "when": "!jaculus.hasProject"
            }
        ]
    },
    "scripts": {
        "fetch:jacly": "node scripts/fetch-jacly.mjs",
        "vscode:prepublish": "npm run compile",
        "compile": "npm run fetch:jacly && node esbuild.cjs --production",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.2",
        "@types/node": "^18.18.0",
        "@types/react": "^18.2.79",
        "@types/react-dom": "^18.2.25",
        "@types/vscode": "1.92.0",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "@vscode/test-electron": "^2.3.5",
        "esbuild": "^0.25.8",
        "eslint": "^8.51.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "@blockly/field-angle": "^6.0.9",
        "@blockly/field-colour": "^6.0.12",
        "@blockly/field-slider": "^8.0.9",
        "@blockly/plugin-cross-tab-copy-paste": "^8.0.8",
        "@blockly/workspace-backpack": "^7.0.11",
        "@jaculus/common": "^0.1.0",
        "@jaculus/device": "^0.1.3",
        "@jaculus/firmware": "^0.1.0",
        "@jaculus/project": "^0.1.2",
        "@kuband/react-blockly": "^10.0.1",
        "blockly": "^12.4.1",
        "chalk": "^5.6.2",
        "lucide-react": "^0.577.0",
        "lucide-static": "^0.577.0",
        "serialport": "^13.0.0",
        "zod": "^4.3.6"
    }
}
