{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "outDir": "out",
        "lib": [
            "ES2020"
        ],
        "types": [
            "node",
            "vscode",
            "mocha"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"]
}
